// Generate the TypeScript client
generator client {
  provider = "prisma-client-js"
}

// Using PostgreSQL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The Tables

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  decks     Deck[]   // A user can have many decks
  createdAt DateTime @default(now())
}

model Deck {
  id          String      @id @default(uuid())
  title       String
  description String?     // '?' = field optional
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards  Flashcard[] // A deck can have many flashcards
  createdAt   DateTime    @default(now())
}

model Flashcard {
  id        String   @id @default(uuid())
  question  String
  answer    String
  deckId    String
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
