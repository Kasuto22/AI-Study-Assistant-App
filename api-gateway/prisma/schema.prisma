// Generate the TypeScript client
generator client {
  provider = "prisma-client-js"
}

// Using PostgreSQL
datasource db {
  provider = "postgresql"
}

// The Tables

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // This will store the hashed password
  decks     Deck[]   // A user can have many decks
  createdAt DateTime @default(now())
}

model Deck {
  id        String      @id @default(uuid())
  title     String
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     Flashcard[] // A deck has many flashcards
  createdAt DateTime    @default(now())
}

model Flashcard {
  id          String   @id @default(uuid())
  front       String
  back        String
  deckId      String
  deck        Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  
  // --- Spaced Repetition Tracking ---
  nextReview  DateTime @default(now()) // When should they see this next?
  easeFactor  Float    @default(2.5)   // How easy is this card?
  interval    Int      @default(0)     // How many days to wait until the next review
  reviewCount Int      @default(0)     // How many times has the user reviewed this card?
}
